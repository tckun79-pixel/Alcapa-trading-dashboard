# Streamlit Cloud Secrets Template
# Copy this file to .streamlit/secrets.toml and fill in your actual values.
# .streamlit/secrets.toml is gitignored — never commit real keys.
#
# Get your Alpaca paper trading API keys from:
# https://app.alpaca.markets/paper/dashboard/overview

[secrets]
APCA_API_KEY_ID = "your_key_id_here"
APCA_API_SECRET_KEY = "your_secret_key_here"
APCA_API_PAPER = "true"

# Auto-refresh interval in seconds (0 = off)
AUTO_REFRESH_INTERVAL = "60"

# Supabase (for trader data sync)
# Create a Supabase project at https://supabase.com, then run supabase_setup_trader.sql
SUPABASE_URL = "https://xxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "eyJ..."  # or SUPABASE_ANON_KEY if using anon with appropriate policies
